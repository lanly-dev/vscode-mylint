{
  "name": "mylint",
  "displayName": "MyLint",
  "description": "Mostly for virtual file",
  "publisher": "lanly-dev",
  "version": "0.0.1",
  "sponsor": {
    "url": "https://github.com/sponsors/lanly-dev"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "eslint",
    "formatter",
    "javascript",
    "typescript"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mylint.openConfig",
        "title": "mylint: Open Global ESLint Configuration File"
      },
      {
        "command": "mylint.openSettings",
        "title": "mylint: Open Settings"
      },
      {
        "command": "mylint.formatFile",
        "title": "mylint: Format File"
      }
    ],
    "configuration": {
      "title": "MyLint",
      "properties": {
        "mylint.rules": {
          "type": "object",
          "default": {},
          "description": "ESLint rule overrides for JS/TS files. Ex: (e.g. \"semi\": [\"error\", \"always\"]).",
          "additionalProperties": true
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "mylint.formatFile",
          "group": "1_modification",
          "when": "editorTextFocus && editorLangId =~ /^(typescript|javascript)$/"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "vsce-package": "vsce package",
    "efix": "eslint . --fix",
    "sfix": "standard --fix"
  },
  "devDependencies": {
    "@types/node": "26.x",
    "@types/vscode": "^1.107.0",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.7.0",
    "standard": "^17.1.2",
    "ts-loader": "^9.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.64.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-jsonc": "3.3.0"
  }
}
